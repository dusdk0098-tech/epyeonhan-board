{
  "name": "epyeonhan-board",
  "version": "1.0.24",
  "description": "PICTURE EDIT 현장 사진 편집 로컬 데스크톱 프로그램",
  "author": "대성건설(주)",
  "main": "dist-electron/electron/main.js",
  "private": true,
  "scripts": {
    "dev": "npm run build:electron && concurrently -k \"vite --host 127.0.0.1 --port 5180\" \"wait-on http://127.0.0.1:5180 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5180 electron .\"",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "tsc -p tsconfig.json && npm run build:electron && vite build",
    "verify:board": "npm run build && node scripts/verify-board-no-gap.cjs && node scripts/verify-preview-fit.cjs && node scripts/verify-output-settings.cjs && node scripts/verify-photo-ledger-pdf.cjs && node scripts/verify-update-utils.cjs && node scripts/verify-auth-setup.cjs && node scripts/verify-ui-structure.cjs",
    "verify:update": "npm run build:electron && node scripts/verify-update-utils.cjs",
    "verify:auth": "npm run build && node scripts/verify-auth-setup.cjs",
    "verify:ui": "npm run build && node scripts/verify-ui-structure.cjs",
    "deploy:admin-functions": "powershell -ExecutionPolicy Bypass -File scripts/deploy-admin-functions.ps1",
    "package:win": "npm run package:win:installer",
    "package:win:fast": "npm run build && electron-builder --win dir --x64 --publish never",
    "package:win:installer": "npm run build && electron-builder --win nsis --x64 --publish never && node scripts/build-update-bridge.cjs",
    "package:win:versioned": "node scripts/package-win-version.cjs",
    "package:win:portable": "npm run build && electron-builder --win portable --x64 --publish never",
    "preview": "vite preview --host 127.0.0.1",
    "start": "npm run build && electron ."
  },
  "build": {
    "appId": "com.daesung.epyeonhanboard",
    "productName": "PEDIT (페딧)",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      }
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/sharp/**/*",
      "node_modules/@img/**/*"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "PEDIT-${version}-${target}.${ext}"
    },
    "protocols": [
      {
        "name": "PEDIT",
        "schemes": [
          "pedit",
          "epyeonhan-board"
        ]
      }
    ],
    "nsis": {
      "artifactName": "PEDIT-${version}-setup.${ext}",
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": false,
      "include": "build/installer.nsh",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PEDIT (페딧)"
    },
    "portable": {
      "artifactName": "PEDIT-${version}-portable.${ext}"
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.1",
    "exifr": "^7.1.3",
    "lucide-react": "^0.468.0",
    "papaparse": "^5.4.1",
    "pdf-lib": "^1.17.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.33.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/papaparse": "^5.3.15",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^10.0.3",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^26.15.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "wait-on": "^8.0.1"
  }
}
